# API URL (Worker Cloudflare)
API_URL=https://spendwise.lopreteangelo97.workers.dev/api

# Solo per `wrangler dev`: copia in workers/.dev.vars e genera un valore casuale.
JWT_SECRET=

# Per sviluppo locale
